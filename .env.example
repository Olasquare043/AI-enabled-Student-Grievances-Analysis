POSTGRES_DB=student_grievances
POSTGRES_USER=app
POSTGRES_PASSWORD=app_password
POSTGRES_PORT=5432

BACKEND_PORT=8000
FRONTEND_PORT=3000

JWT_SECRET=change-this-before-production
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

CACHE_BACKEND=memory
REDIS_URL=redis://redis:6379/0

LLM_PROVIDER=none
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

MONITORING_ENABLED=true
MONITORING_MAX_SAMPLES=2000

RATE_LIMIT_ENABLED=true
RATE_LIMIT_MAX_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_EXEMPT_PATHS=/health,/openapi.json,/docs,/redoc

CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
AUTO_SEED_DEMO_DATA=true
DB_WAIT_TIMEOUT_SECONDS=60
DB_WAIT_INTERVAL_SECONDS=2

INTERNAL_API_BASE_URL=http://backend:8000
NEXT_PUBLIC_API_BASE_URL=/api
